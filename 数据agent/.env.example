# 环境变量配置示例
# 复制此文件为 .env 并配置您的API信息

# ========== 云端API配置 ==========
# API密钥（必填）
API_KEY=your_api_key_here

# API基础地址（必填）
# 例如：https://api.openai.com/v1
API_BASE=your_api_base_url_here

# OCR视觉模型（必填）
# 例如：gpt-4-vision-preview
VISION_MODEL=your_vision_model_here

# 语言模型（必填）
# 例如：gpt-4
LLM_MODEL=your_llm_model_here